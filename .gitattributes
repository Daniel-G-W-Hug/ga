# Normalize all text files to LF in the repository.
# On checkout, Windows gets CRLF for shell scripts; everything else stays LF.
* text=auto eol=lf

# Explicitly mark common binary types so git never mangles them.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.pyd  binary
*.so   binary
*.dll  binary
*.lib  binary
*.exe  binary
